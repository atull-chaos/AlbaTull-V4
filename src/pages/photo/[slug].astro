---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchAllWithCache, getPhotoBySlug as getSanityPhotoBySlug, urlFor } from '../../lib/sanity.js';
import { PHOTOS as LOCAL_PHOTOS, catSlug, getRelatedPhotos } from '../../data/photos.js';

// ── Generate paths from Sanity → Cache → Local fallback ─────────
export async function getStaticPaths() {
  const { photos, source } = await fetchAllWithCache();

  if ((source === 'sanity' || source === 'cache') && photos && photos.length > 0) {
    return photos
      .filter(p => p.slug && p.image)
      .map(p => ({
        params: { slug: p.slug },
        props: { source }
      }));
  }

  // Local fallback
  return LOCAL_PHOTOS.map(photo => ({
    params: { slug: photo.slug },
    props: { source: 'local', photo }
  }));
}

const { slug } = Astro.params;
const { source } = Astro.props;

// ── Fetch photo detail ──────────────────────────────────────────
let photo = null;
let related = [];
let categorySlug = '';
let metadata = null;

if (source === 'cache') {
  // Use cache directly — don't hit Sanity API per-photo
  try {
    const { readCache } = await import('../../lib/sanity-cache.js');
    const cached = (readCache() || { photos: [] }).photos.find(p => p.slug === slug);
    if (cached && cached.image) {
      photo = {
        id:    cached._id,
        title: cached.title || 'Untitled',
        slug:  cached.slug,
        img:   urlFor(cached.image).width(900).quality(65).auto('format').url(),
        desc:  cached.description || '',
        cat:   cached.category?.name || 'Uncategorized',
        audio: cached.audio?.asset?._ref || null
      };
      categorySlug = cached.category?.slug || catSlug(photo.cat);
      metadata = cached.metadata || null;
    }
  } catch (ce) {
    console.warn('Cache read failed for photo:', slug, ce.message);
  }
} else if (source === 'sanity') {
  try {
    const sp = await getSanityPhotoBySlug(slug);
    if (sp && sp.image) {
      photo = {
        id:    sp._id,
        title: sp.title || 'Untitled',
        slug:  sp.slug,
        img:   urlFor(sp.image).width(900).quality(65).auto('format').url(),
        desc:  sp.description || '',
        cat:   sp.category?.name || 'Uncategorized',
        audio: sp.audio?.asset?._ref || null
      };
      categorySlug = sp.category?.slug || catSlug(photo.cat);
      metadata = sp.metadata || null;

      if (sp.related && sp.related.length > 0) {
        related = sp.related
          .filter(r => r.image)
          .map(r => ({
            id:    r._id,
            title: r.title || 'Untitled',
            slug:  r.slug,
            img:   urlFor(r.image).width(600).quality(80).auto('format').url(),
            cat:   r.category?.name || photo.cat
          }));
      }
    }
  } catch (e) {
    console.warn('Sanity photo fetch failed for slug:', slug, e.message);
  }
}

if (!photo) {
  const localPhoto = Astro.props.photo || LOCAL_PHOTOS.find(p => p.slug === slug);
  if (localPhoto) {
    photo = localPhoto;
    categorySlug = catSlug(localPhoto.cat);
    related = getRelatedPhotos(localPhoto);
  }
}

const isFragment = Astro.url.searchParams.get('fragment') === '1';

// Build metadata details string (matches Figma: "Black & white. Digital medium format. 2024.")
const detailParts = [];
if (metadata?.camera) detailParts.push(metadata.camera);
if (metadata?.lens) detailParts.push(metadata.lens);
if (metadata?.focalLength) detailParts.push(metadata.focalLength);
if (metadata?.aperture) detailParts.push(metadata.aperture);
if (metadata?.iso) detailParts.push(`ISO ${metadata.iso}`);
if (metadata?.dateTaken) {
  try { detailParts.push(String(new Date(metadata.dateTaken).getFullYear())); } catch {}
}
const detailsString = detailParts.length > 0 ? detailParts.join('. ') + '.' : '';
---

{isFragment && photo && (
  <Fragment>
    <div class="detail-layout">
      <div class="detail-hero">
        <img src={photo.img} alt={photo.title} data-hero-img />
      </div>
      <div class="detail-sidebar">
        <h1 class="detail-title">{photo.title}</h1>
        {photo.desc && <p class="detail-description">{photo.desc}</p>}

        <div class="detail-meta-table">
          {detailsString && (
            <div class="detail-meta-row">
              <div class="detail-meta-label">Details</div>
              <div class="detail-meta-value">{detailsString}</div>
            </div>
          )}
          {metadata?.location && (
            <div class="detail-meta-row">
              <div class="detail-meta-label">Location</div>
              <div class="detail-meta-value">{metadata.location}</div>
            </div>
          )}
          <div class="detail-meta-row">
            <div class="detail-meta-label">Collection</div>
            <div class="detail-meta-value">
              <a href={`/category/${categorySlug}/`}>{photo.cat}</a>
            </div>
          </div>
          <div class="detail-meta-row">
            <div class="detail-meta-label">Words by Alba</div>
            <div class="detail-meta-value">
              <div class="detail-play-voice">&#9654; Play Voice Note</div>
            </div>
          </div>
        </div>

        {related.length > 0 && (
          <div class="related-section">
            <h2 class="related-title">Related Shots</h2>
            <div class="related-grid">
              {related.map(r => (
                <a class="related-item" href={`/photo/${r.slug}/`} data-overlay-link data-kind="photo" data-still={r.img}>
                  <img src={r.img} alt={r.title} loading="lazy" />
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </Fragment>
)}

{!isFragment && photo && (
  <BaseLayout title={`${photo.title} — Alba Tull`} description={photo.desc} ogImage={photo.img}>
    <div class="detail-layout">
      <div class="detail-hero">
        <canvas id="heroCanvas" data-src={photo.img} data-alt={photo.title}></canvas>
        <noscript><img src={photo.img} alt={photo.title} /></noscript>
      </div>
      <div class="detail-sidebar">
        <a class="detail-back" href={`/category/${categorySlug}/`}>&larr; Back to {photo.cat}</a>
        <h1 class="detail-title">{photo.title}</h1>
        {photo.desc && <p class="detail-description">{photo.desc}</p>}

        <div class="detail-meta-table">
          {detailsString && (
            <div class="detail-meta-row">
              <div class="detail-meta-label">Details</div>
              <div class="detail-meta-value">{detailsString}</div>
            </div>
          )}
          {metadata?.location && (
            <div class="detail-meta-row">
              <div class="detail-meta-label">Location</div>
              <div class="detail-meta-value">{metadata.location}</div>
            </div>
          )}
          <div class="detail-meta-row">
            <div class="detail-meta-label">Collection</div>
            <div class="detail-meta-value">
              <a href={`/category/${categorySlug}/`}>{photo.cat}</a>
            </div>
          </div>
          <div class="detail-meta-row">
            <div class="detail-meta-label">Words by Alba</div>
            <div class="detail-meta-value">
              <div class="detail-play-voice">&#9654; Play Voice Note</div>
            </div>
          </div>
        </div>

        {related.length > 0 && (
          <div class="related-section">
            <h2 class="related-title">Related Shots</h2>
            <div class="related-grid">
              {related.map(r => (
                <a class="related-item" href={`/photo/${r.slug}/`} data-overlay-link data-kind="photo" data-still={r.img}>
                  <img src={r.img} alt={r.title} loading="lazy" />
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Canvas watermark: burns "ALBA TULL" into the image pixels -->
    <script>
      (function() {
        const canvas = document.getElementById('heroCanvas');
        if (!canvas) return;
        const src = canvas.dataset.src;
        const alt = canvas.dataset.alt || '';
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = function() {
          // Size canvas to image
          canvas.width = img.naturalWidth;
          canvas.height = img.naturalHeight;
          const ctx = canvas.getContext('2d');

          // Draw the photo
          ctx.drawImage(img, 0, 0);

          // Burn repeating watermark into pixels
          ctx.save();
          ctx.globalAlpha = 0.07;
          ctx.fillStyle = '#ffffff';
          ctx.font = 'bold 28px Arial, sans-serif';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.rotate(-25 * Math.PI / 180);

          // Tile the watermark across the entire image
          const text = 'ALBA TULL  \u00A9';
          const stepX = 320;
          const stepY = 160;
          for (let y = -canvas.height; y < canvas.height * 2; y += stepY) {
            for (let x = -canvas.width; x < canvas.width * 2; x += stepX) {
              ctx.fillText(text, x, y);
            }
          }
          ctx.restore();

          // Also add a single stronger watermark in the bottom-right corner
          ctx.save();
          ctx.globalAlpha = 0.15;
          ctx.fillStyle = '#ffffff';
          ctx.font = 'bold 20px Arial, sans-serif';
          ctx.textAlign = 'right';
          ctx.textBaseline = 'bottom';
          ctx.fillText('\u00A9 Alba Tull', canvas.width - 20, canvas.height - 16);
          ctx.restore();
        };
        img.onerror = function() {
          // Fallback: show regular img if canvas fails (e.g. CORS)
          const fallback = document.createElement('img');
          fallback.src = src;
          fallback.alt = alt;
          fallback.setAttribute('data-hero-img', '');
          canvas.parentNode.replaceChild(fallback, canvas);
        };
        img.src = src;
      })();
    </script>
  </BaseLayout>
)}
